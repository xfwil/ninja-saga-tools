  "item_field_detection_rules": {
    "_description": "Rules untuk mendeteksi source dari field di library.json dan skills.json. Satu item bisa match MULTIPLE rules = multiple sources.",
    "rules": [
      {
        "field": "buyable",
        "condition": "== true",
        "possible_sources": ["shop_normal", "shop_clan", "shop_pvp", "shop_crew", "academy"],
        "note": "Cek juga gamedata.json shop.normal/clan/pvp/crew untuk konfirmasi di shop mana"
      },
      {
        "field": "price_gold",
        "condition": "> 0",
        "possible_sources": ["shop_normal", "shop_clan", "academy"],
        "note": "Gold price biasanya normal shop atau academy"
      },
      {
        "field": "price_tokens",
        "condition": "> 0",
        "possible_sources": ["shop_normal", "shop_pvp", "limited_store", "special_deals", "billing_packages"],
        "note": "Token items bisa dari berbagai sumber"
      },
      {
        "field": "price_pvp",
        "condition": "> 0",
        "possible_sources": ["shop_pvp"],
        "note": "Hanya PvP shop"
      },
      {
        "field": "item_price_pvp",
        "condition": "> 0",
        "possible_sources": ["shop_pvp"],
        "note": "PvP shop untuk skills"
      },
      {
        "field": "price_prestige",
        "condition": "> 0",
        "possible_sources": ["clan_forge", "shop_clan"],
        "note": "Prestige = clan currency"
      },
      {
        "field": "price_merit",
        "condition": "> 0",
        "possible_sources": ["shop_crew"],
        "note": "Merit = Shadow Crew currency"
      },
      {
        "field": "premium",
        "condition": "== true",
        "possible_sources": ["billing_packages", "special_deals", "limited_store"],
        "note": "Premium items biasanya dari cash shop atau special deals"
      },
      {
        "field": "buyable",
        "condition": "== false",
        "possible_sources": ["event_seasonal", "mission_reward", "blacksmith", "material_market", "hunting_market", "dragon_gacha", "daily_gacha", "divine_tree", "giveaway_center"],
        "note": "Non-buyable items = event drops, forge results, gacha, atau discontinued"
      }
    ]
  },

